{
  "name": "boss-talent-indexer",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Local RPA helper for indexing visible BOSS Zhipin talent search results.",
  "scripts": {
    "capture": "node src/capture-boss.js",
    "capture:chrome-ax": "node src/capture-chrome-ax.js",
    "capture:python": "python3 python/boss_capture.py",
    "capture:cdp": ".venv/bin/python python/boss_cdp_capture.py",
    "capture:jobs": ".venv/bin/python python/boss_jobs_cdp_capture.py",
    "org:intel": ".venv/bin/python python/org_intel_agent.py",
    "org:service": "PYTHONPATH=python .venv/bin/uvicorn org_intel_service:app --host 127.0.0.1 --port 8787",
    "report:org": ".venv/bin/python python/org_report.py",
    "test:python": "python3 -m unittest discover -s tests -p 'test_*.py'",
    "test": "node --test tests/*.test.js"
  },
  "dependencies": {
    "playwright-core": "^1.52.0"
  },
  "devDependencies": {}
}
